{
  "compilerOptions": {
    "noImplicitAny": false,
    "allowJs": true,
    "target": "es2022",
    "lib": [
      "es2022"
    ],
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src/server",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/server"
  ],
  "exclude": [
    "node_modules",
    "src/server/**/*.test.js",
    "**/*.test.ts"
  ]
}
