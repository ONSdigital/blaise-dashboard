    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "axios-mock-adapter": "^2.1.0",
    "babel-jest": "^30.4.1",
    "concurrently": "^10.0.3",
